                <alias key='&quot;railway&quot;' value='Railway' />
                <alias key='&quot;roundabout&quot;' value='Roundabout' />
                <alias key='&quot;station&quot;' value='Station' />
                <alias key='&quot;stop&quot;' value='Stop' />
