    <worksheet name='Infrastructure Risk by POI Type'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Anthropic Sans,sans-serif'>Infrastructure Risk by POI Type</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Anthropic Sans,sans-serif' fontsize='10'>Junctions are the riskiest POI (29.53% high-severity rate). Traffic signals have the most total accidents (1.06M) but lower severity. Roundabouts are safest (5.02%). Target junction redesign for greatest safety impact.</run>
          </formatted-text>
        </caption>
      </layout-options>
